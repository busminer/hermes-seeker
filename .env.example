GEMINI_API_KEY=your_google_ai_studio_key

# Optional overrides
SEEKER_USER_NAME=Alex
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Zephyr
HERMES_API_URL=http://127.0.0.1:8642
API_SERVER_KEY=hermes-seeker-local-dev

# Optional: full path to the Hermes binary if your packaged GUI app cannot find
# it on PATH. Usually not required when Hermes gateway is already running.
# macOS/Linux example:
# HERMES_BIN=/home/you/.local/bin/hermes
# Windows example:
# HERMES_BIN=C:\\Users\\you\\AppData\\Local\\Programs\\hermes\\hermes.exe
